# ── App ───────────────────────────────────────────────────────────────────────
PORT=4000
CLIENT_URL=http://localhost:5173
# Your server's public URL (used for OAuth redirect URIs)
SERVER_URL=http://localhost:4000

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Get this free at: https://cloud.mongodb.com
# Create M0 cluster → Connect → Drivers → copy URI, replace <password>
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/eventify?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_char_random_hex
JWT_EXPIRES_IN=7d

# ── Cloudinary ────────────────────────────────────────────────────────────────
# Free at: https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Google (Drive + YouTube share same credentials) ───────────────────────────
# Setup: https://console.cloud.google.com → Create project → Enable Drive API + YouTube Data API v3
# Create OAuth 2.0 Client ID → Web application
# Add redirect URIs: {SERVER_URL}/api/auth/google/callback and {SERVER_URL}/api/social/youtube/callback
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback

# ── Anthropic Claude (AI caption generation) ──────────────────────────────────
# Get free trial credits at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Facebook & Instagram (same Meta Developer App) ────────────────────────────
# Setup: https://developers.facebook.com → Create App → Add Facebook Login + Instagram Graph API
# Redirect URI: {SERVER_URL}/api/social/facebook/callback
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# ── TikTok ────────────────────────────────────────────────────────────────────
# Setup: https://developers.tiktok.com → Create App → Add Content Posting API
# Redirect URI: {SERVER_URL}/api/social/tiktok/callback
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret

# ── X / Twitter ───────────────────────────────────────────────────────────────
# Setup: https://developer.twitter.com → Create Project + App → OAuth 2.0
# Redirect URI: {SERVER_URL}/api/social/twitter/callback
# Note: Media upload requires Twitter API Basic tier (~$100/mo)
TWITTER_CLIENT_ID=your_twitter_client_id
TWITTER_CLIENT_SECRET=your_twitter_client_secret
