# ── Eventify Client Environment Variables ─────────────────────────────────────
#
# For development: these are picked up by Vite automatically.
# For production (Vercel): set them in the Vercel dashboard under
#   Project Settings → Environment Variables
#
# IMPORTANT: all variables exposed to the browser MUST be prefixed VITE_

# Your Render.com server URL (no trailing slash)
# Leave empty in development — Vite proxy handles /api automatically
VITE_API_URL=https://your-eventify-server.onrender.com

# App name shown in browser title (optional)
VITE_APP_NAME=Eventify
